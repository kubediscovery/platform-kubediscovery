# kd-store — environment variables
# Copy to .env for local development (loaded by godotenv in setup.go)

# Application
APP_NAME=kd-store
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info

# PostgreSQL (pgx pool)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=kubediscovery
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL_MODE=disable

# Pool tuning
DATABASE_MAX_CONNS=10
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=1h
DATABASE_MAX_CONN_IDLE_TIME=30m
DATABASE_HEALTH_CHECK_PERIOD=1m

# Redis (go-redis)
CACHE_ADDR=localhost:6379
CACHE_PASSWORD=
CACHE_DB=0

# Redis pool/timeout tuning
CACHE_MAX_RETRIES=3
CACHE_MIN_RETRY_BACKOFF=8ms
CACHE_MAX_RETRY_BACKOFF=512ms
CACHE_DIAL_TIMEOUT=5s
CACHE_READ_TIMEOUT=3s
CACHE_WRITE_TIMEOUT=3s
CACHE_POOL_SIZE=10
CACHE_MIN_IDLE_CONNS=2
CACHE_POOL_TIMEOUT=4s
