# kd-agent environment variables

# --- Identity ---
# Unique identifier for this agent instance. Becomes caller_id in every gRPC frame.
# REQUIRED — the agent will fail to start if this is absent.
AGENT_ID=kd-agent

# --- Gateway connection ---
GRPC_ADDR=localhost:50051

# --- mTLS certificates ---
GRPC_CA_FILE=~/.kubediscovery/certs/staging/ca.crt
GRPC_CLIENT_CERT_FILE=~/.kubediscovery/certs/staging/client.crt
GRPC_CLIENT_KEY_FILE=~/.kubediscovery/certs/staging/client.key

# --- Application ---
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info
