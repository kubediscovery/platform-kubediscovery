# kd-gateway environment variables
# Copy to .env and fill in values for local development.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=kd-gateway
APP_ENVIRONMENT=development
APP_LOG_LEVEL=info          # debug | info | warn | error

# ─── gRPC Server ──────────────────────────────────────────────────────────────
GRPC_ADDR=0.0.0.0:50051

# Server TLS certificate and private key (required)
GRPC_CERT_FILE=~/.kubediscovery/certs/staging/srv.crt
GRPC_KEY_FILE=~/.kubediscovery/certs/staging/srv.key

# Mutual TLS: set to false to accept connections without client certificates
GRPC_MTLS=true

# CA certificate used to verify client certificates (required when GRPC_MTLS=true)
GRPC_CLIENT_CA_FILE=~/.kubediscovery/certs/staging/ca.crt

# Enable per-call duration debug interceptors
GRPC_DEBUG=false

# ─── Agent behaviour ──────────────────────────────────────────────────────────
# What to do when a second connection arrives with the same caller_id:
#   reject_new      — reject the incoming stream with AlreadyExists (default, safest)
#   evict_previous  — terminate the existing stream and accept the new one
AGENT_DUPLICATE_POLICY=reject_new
